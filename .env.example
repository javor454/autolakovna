# Resend (https://resend.com) — email přes fetch, bez další npm knihovny
RESEND_API_KEY=
# Ověřená doména v Resend, např. Lakovna <poptavky@vasdomena.cz>
MAIL_FROM=
# Kam chodí upozornění
MAIL_TO=

# Google Drive — service account se sdíleným přístupem ke složce (Editor)
GOOGLE_CLIENT_EMAIL=
# Celý private key včetně -----BEGIN...-----; v .env můžete použít více řádků nebo \n
GOOGLE_PRIVATE_KEY=
DRIVE_FOLDER_ID=
