# Vercel CLI (make dev v Dockeru) — token z https://vercel.com/account/tokens
# `make vercel-login` token nepoužívá (vždy interaktivní OAuth). S VERCEL_TOKEN stačí `make dev` / `make vercel-whoami`.
VERCEL_TOKEN=

# Google Drive — zvolte OAuth NEBO service account (OAuth má přednost)
#
# OAuth (vhodné pro osobní Disk; bez Google Workspace)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Consent screen: …/auth/drive (výchozí skript). Užší: GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/drive.file
# Jednorázově: make drive-oauth-token  (nebo: node --env-file=.env scripts/google-oauth-token.mjs)
# V GCP musí „Authorized redirect URIs" přesně odpovídat řádku ze skriptu (včetně koncového /).
# Výchozí: http://127.0.0.1:8765/ — u localhost: GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8765/
GOOGLE_REFRESH_TOKEN=
#
# Service account (kvóta jen se Shared drive ve Workspace)
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
#
DRIVE_FOLDER_ID=

# --- E-mail (Resend) — volitelné, než budete mít ověřenou doménu nechte zakomentované ---
# Formulář funguje i bez toho: soubory jdou na Drive, e-mail se jen neodešle.
# https://resend.com — po ověření domény odkomentujte a doplňte:
# RESEND_API_KEY=
# MAIL_FROM=Lak&Go <poptavky@vasdomena.cz>
# MAIL_TO=vas@email.cz
